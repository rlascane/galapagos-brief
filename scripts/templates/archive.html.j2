<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Arquivo — Briefing Galapagos</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,500&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="../assets/style.css" />
</head>
<body>
  <div class="page">

    <header class="masthead">
      <div class="masthead__rule"></div>
      <div class="masthead__row">
        <div class="masthead__brand">
          <div class="masthead__title">Arquivo</div>
          <div class="masthead__sub">Briefing Matinal · Galapagos Capital</div>
        </div>
        <div class="masthead__meta">
          <div class="masthead__date">{{ archive | length }} edição{% if archive | length != 1 %}ões{% endif %}</div>
        </div>
      </div>
      <div class="masthead__rule masthead__rule--thick"></div>
    </header>

    <nav class="topnav">
      <a href="../index.html" class="topnav__link">← Última edição</a>
    </nav>

    <main class="archive">
      {% if not archive %}
      <p class="archive__empty">Nenhuma edição publicada ainda.</p>
      {% else %}
      <ol class="archive__list">
        {% for item in archive %}
        <li class="archive__item">
          <a href="{{ item.filename }}" class="archive__link">
            <div class="archive__date">{{ item.date_pt }}</div>
            {% if item.teaser %}
            <div class="archive__teaser">{{ item.teaser }}</div>
            {% endif %}
          </a>
        </li>
        {% endfor %}
      </ol>
      {% endif %}
    </main>

    <footer class="colophon">
      <div class="colophon__rule"></div>
      <div class="colophon__row">
        <div class="colophon__left">
          <span class="colophon__brand">Galapagos Capital</span>
          <span class="colophon__sep">·</span>
          <span>Uso interno</span>
        </div>
      </div>
    </footer>

  </div>
</body>
</html>
